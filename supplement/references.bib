@article{fehr-duda_probability_2012,
	title = {Probability and {Risk}: {Foundations} and {Economic} {Implications} of {Probability}-{Dependent} {Risk} {Preferences}},
	volume = {4},
	issn = {1941-1383, 1941-1391},
	shorttitle = {Probability and {Risk}},
	url = {https://www.annualreviews.org/content/journals/10.1146/annurev-economics-080511-110950},
	doi = {10.1146/annurev-economics-080511-110950},
	abstract = {A large body of evidence has documented that risk preferences depend nonlinearly on outcome probabilities. We discuss the foundations and economic consequences of probability-dependent risk preferences and offer a practitioner\&apos;s guide to understanding and modeling probability dependence. We argue that probability dependence provides a unifying framework for explaining many real-world phenomena, such as the equity premium puzzle, the long-shot bias in betting markets, and households\&apos; underdiversification and their willingness to buy small-scale insurance at exorbitant prices. Recent findings indicate that probability dependence is not just a feature of laboratory data, but is indeed manifest in financial, insurance, and betting markets. The neglect of probability dependence may prevent researchers from understanding and predicting important phenomena.},
	language = {en},
	number = {Volume 4, 2012},
	urldate = {2024-10-28},
	journal = {Annual Review of Economics},
	author = {Fehr-Duda, Helga and Epper, Thomas},
	month = sep,
	year = {2012},
	pages = {567--593},
}

@article{miller_magical_1956,
